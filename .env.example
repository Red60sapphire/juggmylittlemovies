# === REQUIRED ===
TMDB_ACCESS_TOKEN=your_tmdb_access_token_here

# === SUPABASE (for accounts, watch parties, sync) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# === OPTIONAL but recommended for watch parties ===
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === OPTIONAL ===
AUTH_SESSION_SECRET=a_random_64_char_secret
NEXT_PUBLIC_SITE_URL=https://juggmylittlemovies.com

# === HOW TO GET THESE ===
# TMDB: https://www.themoviedb.org/settings/api → create API key, use "Access Token"
# Supabase: https://supabase.com → new project → Project Settings > API
#   - URL: Project Settings > API > Project URL
#   - Anon Key: Project Settings > API > anon public
#   - Service Role Key: Project Settings > API > service_role (keep secret!)
# AUTH_SESSION_SECRET: run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
